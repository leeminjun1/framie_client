# Framie Client 환경 변수
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워주세요.
#   cp .env.example .env

# Framie API 서버 베이스 URL (framie_server)
# 로컬 기본값과 동일하면 생략해도 됩니다.
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Supabase 프로젝트 (스토리지 공개 URL 조합용)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
